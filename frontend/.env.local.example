
# !! Don't put secrets in this file. Use .env.local for secrets instead !!
# This file is checked into your git repo and provides defaults for non-sensitive
# env vars when running `next dev` only.
# Learn more: https://nextjs.org/docs/app/building-your-application/configuring/environment-variables

# If you deploy to a subpath, change this to the subpath so relative paths work correctly.
# Learn more: https://nextjs.org/docs/app/building-your-application/configuring/environment-variables

# ============================================================================
# BASE CONFIGURATION
# ============================================================================

# Base path for the application (use if deploying to a subpath)
# See: frontend/src/constants/environments.ts
NEXT_PUBLIC_BASE_PATH=

# Base URL for the Next.js application (used in server-side code)
# See: frontend/src/constants/environments.ts
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Environment setting: local, dev, stage, training, test, or prod
# Determines which legacy host URL is used (see legacyHost() in environments.ts)
# See: frontend/src/constants/environments.ts
ENVIRONMENT=dev

# ============================================================================
# API CONFIGURATION
# ============================================================================

# URL for the local API server
# See: frontend/src/constants/environments.ts
API_URL=http://localhost:8080

# Authentication token for local API calls (hardcoded for local development)
# See: frontend/src/constants/environments.ts
API_AUTH_TOKEN=LOCAL_AUTH_12345678

# API Gateway authentication key for local development
# See: frontend/src/constants/environments.ts
API_GW_AUTH=local-dev-api-key

# JWT public key for API token validation (optional, only if needed for your setup)
# See: frontend/src/constants/environments.ts
API_JWT_PUBLIC_KEY=

# ============================================================================
# AUTHENTICATION CONFIGURATION
# ============================================================================

# Authentication endpoint for user login
# See: frontend/src/constants/environments.ts
AUTH_LOGIN_URL=http://localhost:8080/v1/users/login

# Session expiration time in milliseconds (1 year for local development)
# See: frontend/src/constants/environments.ts
AUTH_EXPIRATION_TIME=31536000000

# Session encryption secret (change this to a unique value for your local setup)
# See: frontend/src/constants/environments.ts
# See: frontend/tests/e2e/playwright-env.ts
SESSION_SECRET=extraSecretSessionSecretValueSssh


# ============================================================================
# EMAIL SERVICE (SENDY) - OPTIONAL
# ============================================================================
# Only needed if testing email functionality
# See: frontend/src/constants/environments.ts

SENDY_API_KEY=
SENDY_API_URL=
SENDY_LIST_ID=

# ============================================================================
# FEATURE FLAGS
# ============================================================================
# Set to "true" to disable features, leave blank to enable
# See: frontend/src/constants/environments.ts (envFeatureFlags object)

FEATURE_APPLY_FORM_PROTOTYPE_OFF=
FEATURE_AWARD_RECOMMENDATION_OFF=
FEATURE_FEATURE_FLAG_ADMIN_OFF=
FEATURE_MAINTENANCE_MODE=
FEATURE_OPPORTUNITIES_LIST_OFF=

# ============================================================================
# SEARCH AND DATA
# ============================================================================

# Set to "true" to use mock data instead of live API calls for search
# See: frontend/src/constants/environments.ts
USE_SEARCH_MOCK_DATA=false

# ============================================================================
# MONITORING - OPTIONAL
# ============================================================================
# Only needed if testing performance monitoring with New Relic
# See: frontend/src/constants/environments.ts

NEW_RELIC_ENABLED=false
NEW_RELIC_APP_NAME=
NEW_RELIC_LICENSE_KEY= 

# See documentation/frontend/development.md (line 245). 

# ============================================================================
# BUILD AND RUNTIME SETTINGS
# ============================================================================
# Typically auto-set by Next.js, optional to override
# See: frontend/src/constants/environments.ts

NEXT_BUILD=false
NEXT_RUNTIME=

# CI indicator for build systems
# See: frontend/src/constants/environments.ts
# See: frontend/tests/e2e/playwright-env.ts
CI=
# IMPORTANT!!
# CI=false is unsafe!! In frontend/next.config.js, Boolean(process.env.CI) (line 141) treats "false" as truthy that results in adding security headers locally to be skipped. It is recommended to leave CI as blank. 


# ============================================================================
# PLAYWRIGHT E2E TESTING - OPTIONAL
# ============================================================================
# Only needed if running end-to-end tests with Playwright
# See: frontend/tests/e2e/playwright-env.ts

# Target environment for playwright tests (local or staging)
PLAYWRIGHT_TARGET_ENV=local

# Base URL for local Playwright tests (override if running on different host/port)
LOCAL_BASE_URL=http://127.0.0.1:3000

# Base URL for staging Playwright tests
STAGING_BASE_URL=https://staging.simpler.grants.gov

# Test user credentials for staging E2E tests (only needed if testing against staging)
STAGING_TEST_USER_EMAIL=
STAGING_TEST_USER_PASSWORD=
STAGING_TEST_USER_MFA_KEY=

# Authentication token for E2E test logins (must sync with API seed data)
E2E_USER_AUTH_TOKEN=

# Playwright shard configuration (for parallel test execution)
TOTAL_SHARDS=
CURRENT_SHARD=
